# pinecone_write_safety.rules
# Technology: pinecone | Capability: write

rule pinecone-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_pinecone_PATTERN"
  MESSAGE "Blocked an unsafe pattern in pinecone. Use the recommended best practices for 2025/2026."
}

rule pinecone-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_pinecone_API"
  MESSAGE "You are using an outdated API for pinecone. Please upgrade to the newer API."
}
